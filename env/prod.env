# Compose project
COMPOSE_PROJECT_NAME=hsp-infra-prod

# MySQL
MYSQL_PORT=3306
MYSQL_HOST_PORT=3306
MYSQL_ROOT_PASSWORD=root
MYSQL_DEFAULT_DATABASE=user_db

# Nginx (prod host binds fixed 80/443 from docker-compose.prod.yml)
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_HOST_PORT=80
NGINX_SSL_HOST_PORT=443

# Frontend
FRONTEND_PORT=80
FRONTEND_HOST_PORT=3000
FRONTEND_API_BASE_URL=/api

# Service internal ports
USER_SERVICE_PORT=8080
ORDER_SERVICE_PORT=8080
WORKER_SCHEDULE_SERVICE_PORT=8080
DISPATCH_SERVICE_PORT=8080
EXECUTION_RECORD_SERVICE_PORT=8080
PAYMENT_SETTLEMENT_SERVICE_PORT=8080

# User service runtime envs
HSP_USER_SERVICE_SERVICE_NAME=hsp-user-service
HSP_USER_SERVICE_ENV=dev
HSP_USER_SERVICE_LOG_LEVEL=INFO
HSP_USER_SERVICE_GRPC_HOST=0.0.0.0
HSP_USER_SERVICE_GRPC_PORT=50051
HSP_USER_SERVICE_GRPC_TARGET=127.0.0.1:50051
HSP_USER_SERVICE_HTTP_HOST=0.0.0.0
HSP_USER_SERVICE_HTTP_PORT=8080
HSP_USER_SERVICE_USE_MOCK_REPOSITORY=false
HSP_USER_SERVICE_MYSQL_DSN=mysql+aiomysql://root:root@mysql:3306/user_db

# Order service runtime envs
HSP_ORDER_SERVICE_SERVICE_NAME=hsp-order-service
HSP_ORDER_SERVICE_ENV=dev
HSP_ORDER_SERVICE_LOG_LEVEL=INFO
HSP_ORDER_SERVICE_GRPC_HOST=0.0.0.0
HSP_ORDER_SERVICE_GRPC_PORT=50051
HSP_ORDER_SERVICE_GRPC_TARGET=127.0.0.1:50051
HSP_ORDER_SERVICE_HTTP_HOST=0.0.0.0
HSP_ORDER_SERVICE_HTTP_PORT=8080
HSP_ORDER_SERVICE_USE_MOCK_REPOSITORY=false
HSP_ORDER_SERVICE_MYSQL_DSN=mysql+aiomysql://root:root@mysql:3306/order_db

# Worker schedule service runtime envs
HSP_WORKER_SCHEDULE_SERVICE_SERVICE_NAME=hsp-worker-schedule-service
HSP_WORKER_SCHEDULE_SERVICE_ENV=dev
HSP_WORKER_SCHEDULE_SERVICE_LOG_LEVEL=INFO
HSP_WORKER_SCHEDULE_SERVICE_GRPC_HOST=0.0.0.0
HSP_WORKER_SCHEDULE_SERVICE_GRPC_PORT=50051
HSP_WORKER_SCHEDULE_SERVICE_GRPC_TARGET=127.0.0.1:50051
HSP_WORKER_SCHEDULE_SERVICE_HTTP_HOST=0.0.0.0
HSP_WORKER_SCHEDULE_SERVICE_HTTP_PORT=8080
HSP_WORKER_SCHEDULE_SERVICE_USE_MOCK_REPOSITORY=false
HSP_WORKER_SCHEDULE_SERVICE_MYSQL_DSN=mysql+aiomysql://root:root@mysql:3306/schedule_db

# Dispatch service runtime envs
HSP_DISPATCH_SERVICE_SERVICE_NAME=hsp-dispatch-service
HSP_DISPATCH_SERVICE_ENV=dev
HSP_DISPATCH_SERVICE_LOG_LEVEL=INFO
HSP_DISPATCH_SERVICE_GRPC_HOST=0.0.0.0
HSP_DISPATCH_SERVICE_GRPC_PORT=50051
HSP_DISPATCH_SERVICE_GRPC_TARGET=127.0.0.1:50051
HSP_DISPATCH_SERVICE_HTTP_HOST=0.0.0.0
HSP_DISPATCH_SERVICE_HTTP_PORT=8080
HSP_DISPATCH_SERVICE_USE_MOCK_REPOSITORY=false
HSP_DISPATCH_SERVICE_MYSQL_DSN=mysql+aiomysql://root:root@mysql:3306/dispatch_db

# Execution record service runtime envs
HSP_EXECUTION_RECORD_SERVICE_SERVICE_NAME=hsp-execution-record-service
HSP_EXECUTION_RECORD_SERVICE_ENV=dev
HSP_EXECUTION_RECORD_SERVICE_LOG_LEVEL=INFO
HSP_EXECUTION_RECORD_SERVICE_GRPC_HOST=0.0.0.0
HSP_EXECUTION_RECORD_SERVICE_GRPC_PORT=50051
HSP_EXECUTION_RECORD_SERVICE_GRPC_TARGET=127.0.0.1:50051
HSP_EXECUTION_RECORD_SERVICE_HTTP_HOST=0.0.0.0
HSP_EXECUTION_RECORD_SERVICE_HTTP_PORT=8080
HSP_EXECUTION_RECORD_SERVICE_USE_MOCK_REPOSITORY=false
HSP_EXECUTION_RECORD_SERVICE_MYSQL_DSN=mysql+aiomysql://root:root@mysql:3306/execution_db

# Payment settlement service runtime envs
HSP_PAYMENT_SETTLEMENT_SERVICE_SERVICE_NAME=hsp-payment-settlement-service
HSP_PAYMENT_SETTLEMENT_SERVICE_ENV=dev
HSP_PAYMENT_SETTLEMENT_SERVICE_LOG_LEVEL=INFO
HSP_PAYMENT_SETTLEMENT_SERVICE_GRPC_HOST=0.0.0.0
HSP_PAYMENT_SETTLEMENT_SERVICE_GRPC_PORT=50051
HSP_PAYMENT_SETTLEMENT_SERVICE_GRPC_TARGET=127.0.0.1:50051
HSP_PAYMENT_SETTLEMENT_SERVICE_HTTP_HOST=0.0.0.0
HSP_PAYMENT_SETTLEMENT_SERVICE_HTTP_PORT=8080
HSP_PAYMENT_SETTLEMENT_SERVICE_USE_MOCK_REPOSITORY=false
HSP_PAYMENT_SETTLEMENT_SERVICE_MYSQL_DSN=mysql+aiomysql://root:root@mysql:3306/payment_db

# Service host ports (unused in prod override, kept for interpolation completeness)
USER_SERVICE_HOST_PORT=18081
ORDER_SERVICE_HOST_PORT=18082
WORKER_SCHEDULE_SERVICE_HOST_PORT=18083
DISPATCH_SERVICE_HOST_PORT=18084
EXECUTION_RECORD_SERVICE_HOST_PORT=18085
PAYMENT_SETTLEMENT_SERVICE_HOST_PORT=18086

# Health paths (default)
USER_SERVICE_HEALTH_PATH=/health
ORDER_SERVICE_HEALTH_PATH=/health
WORKER_SCHEDULE_SERVICE_HEALTH_PATH=/health
DISPATCH_SERVICE_HEALTH_PATH=/health
EXECUTION_RECORD_SERVICE_HEALTH_PATH=/health
PAYMENT_SETTLEMENT_SERVICE_HEALTH_PATH=/health

# Database names
USER_DB_NAME=user_db
ORDER_DB_NAME=order_db
SCHEDULE_DB_NAME=schedule_db
DISPATCH_DB_NAME=dispatch_db
EXECUTION_DB_NAME=execution_db
PAYMENT_DB_NAME=payment_db
