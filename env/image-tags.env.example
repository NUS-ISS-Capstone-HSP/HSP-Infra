# Copy to env/image-tags.env and adjust tags per environment.
# Default registry follows: ghcr.io/<org>/<service>

USER_SERVICE_IMAGE=ghcr.io/nus-iss-capstone-hsp/user-service
USER_SERVICE_TAG=latest

ORDER_SERVICE_IMAGE=ghcr.io/nus-iss-capstone-hsp/order-service
ORDER_SERVICE_TAG=latest

WORKER_SCHEDULE_SERVICE_IMAGE=ghcr.io/nus-iss-capstone-hsp/worker-schedule-service
WORKER_SCHEDULE_SERVICE_TAG=latest

DISPATCH_SERVICE_IMAGE=ghcr.io/nus-iss-capstone-hsp/dispatch-service
DISPATCH_SERVICE_TAG=latest

EXECUTION_RECORD_SERVICE_IMAGE=ghcr.io/nus-iss-capstone-hsp/execution-record-service
EXECUTION_RECORD_SERVICE_TAG=latest

PAYMENT_SETTLEMENT_SERVICE_IMAGE=ghcr.io/nus-iss-capstone-hsp/payment-settlement-service
PAYMENT_SETTLEMENT_SERVICE_TAG=latest

FRONTEND_IMAGE=ghcr.io/nus-iss-capstone-hsp/frontend
FRONTEND_TAG=latest
