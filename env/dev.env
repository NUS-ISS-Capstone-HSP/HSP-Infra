# Compose project
COMPOSE_PROJECT_NAME=hsp-infra-dev

# MySQL
MYSQL_PORT=3306
MYSQL_HOST_PORT=3306
MYSQL_ROOT_PASSWORD=root
MYSQL_DEFAULT_DATABASE=user_db

# Nginx (container listens on 80/443)
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_HOST_PORT=8080
NGINX_SSL_HOST_PORT=8443

# Frontend
FRONTEND_PORT=80
FRONTEND_HOST_PORT=3000
FRONTEND_API_BASE_URL=/api

# API Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8081
GATEWAY_JWT_SECRET=dev-only-change-me
JWT_ISSUER=hsp-user-service
JWT_AUDIENCE=hsp-api
USER_GRPC_TARGET=user-service:50051
ORDER_GRPC_TARGET=order-service:50052
DISPATCH_GRPC_TARGET=dispatch-service:50054
WORKER_SCHEDULE_GRPC_TARGET=worker-schedule-service:50055
FINANCE_GRPC_TARGET=payment-settlement-service:50053
GRPC_TIMEOUT_MS=3000
API_GATEWAY_HEALTH_PATH=/healthz
API_GATEWAY_NGINX_HEALTH_PATH=/api/healthz

# Service internal ports
USER_SERVICE_PORT=8080
ORDER_SERVICE_PORT=8080
WORKER_SCHEDULE_SERVICE_PORT=8080
DISPATCH_SERVICE_PORT=8080
EXECUTION_RECORD_SERVICE_PORT=8080
PAYMENT_SETTLEMENT_SERVICE_PORT=8080

# Service host ports (dev only)
USER_SERVICE_HOST_PORT=18081
ORDER_SERVICE_HOST_PORT=18082
WORKER_SCHEDULE_SERVICE_HOST_PORT=18083
DISPATCH_SERVICE_HOST_PORT=18084
EXECUTION_RECORD_SERVICE_HOST_PORT=18085
PAYMENT_SETTLEMENT_SERVICE_HOST_PORT=18086

# Health paths (default)
USER_SERVICE_HEALTH_PATH=/health
ORDER_SERVICE_HEALTH_PATH=/health
WORKER_SCHEDULE_SERVICE_HEALTH_PATH=/health
DISPATCH_SERVICE_HEALTH_PATH=/health
EXECUTION_RECORD_SERVICE_HEALTH_PATH=/health
PAYMENT_SETTLEMENT_SERVICE_HEALTH_PATH=/health

# Database names
USER_DB_NAME=user_db
ORDER_DB_NAME=order_db
SCHEDULE_DB_NAME=schedule_db
DISPATCH_DB_NAME=dispatch_db
EXECUTION_DB_NAME=execution_db
PAYMENT_DB_NAME=payment_db

# Smoke test endpoint placeholders (override when real APIs are ready)
SMOKE_USERS_PATH=/api/users/health
SMOKE_ORDERS_PATH=/api/orders/health
SMOKE_GATEWAY_HEALTH_PATH=/api/healthz

# Order flow placeholders (override to match actual API contracts)
ORDER_FLOW_CREATE_USER_URL=http://localhost:8080/api/users
ORDER_FLOW_CREATE_ORDER_URL=http://localhost:8080/api/orders
ORDER_FLOW_CREATE_USER_PAYLOAD='{"name":"infra-smoke-user"}'
ORDER_FLOW_CREATE_ORDER_PAYLOAD='{"userId":"infra-smoke-user","productId":"demo-sku","quantity":1}'
